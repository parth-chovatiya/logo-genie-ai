PORT=3000

# Public base URL used for SEO (metadata, sitemap, robots). Example:
# NEXT_PUBLIC_SITE_URL=https://logogenie.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Gemini / Generative AI
GEMINI_API_KEY=your_gemini_api_key_here
# Or alternatively:
# GOOGLE_AI_API_KEY=your_gemini_api_key_here

# AWS S3 (for logo storage)
ACCESS_KEY=your_aws_access_key_id_here
ACCESS_SECRET_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_LOGO_BUCKET=your_s3_bucket_name_here

# Optional: database / other services
# DATABASE_URL=postgres://user:password@host:5432/dbname
